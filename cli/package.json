{
  "name": "@microsoft/events-cli",
  "version": "0.3.0",
  "description": "CLI for searching Microsoft flagship event sessions (Build, Ignite).",
  "type": "module",
  "bin": {
    "msevents": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "smoke:fixture": "node scripts/smoke-fixture.mjs",
    "smoke:live": "node scripts/smoke-live.mjs",
    "test": "vitest run"
  },
  "keywords": [
    "microsoft",
    "events",
    "build",
    "ignite",
    "sessions",
    "cli"
  ],
  "author": "Microsoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/Build-CLI.git",
    "directory": "cli"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "env-paths": "^4.0.0",
    "minisearch": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
